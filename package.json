{
  "name": "@dirupt/adonis-lucid-filter",
  "description": "Addon for filtering AdonisJS Lucid ORM (fork with AdonisJS v7 support)",
  "version": "6.0.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./build/index.js",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "exports": {
    ".": "./build/index.js",
    "./commands": "./build/commands/main.js",
    "./types/*": "./build/src/types/*.js",
    "./bindings": "./build/src/bindings/model_query_builder.js",
    "./provider": "./build/providers/lucid_filter_provider.js"
  },
  "scripts": {
    "lint": "eslint",
    "clean": "del-cli build",
    "precompile": "npm run lint && npm run clean",
    "postcompile": "npm run copy:stubs && npm run index:commands",
    "compile": "tsup-node && tsc --emitDeclarationOnly --declaration",
    "build": "npm run compile",
    "copy:stubs": "copyfiles \"stubs/**/**/*.stub\" --up=\"1\" build",
    "index:commands": "adonis-kit index build/commands",
    "quick:test": "node --enable-source-maps --import=@poppinss/ts-exec bin/test.ts",
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "typecheck": "tsc --noEmit",
    "version": "npm run build",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@changesets/cli": "^2.31.0",
    "@japa/assert": "^4.2.0",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@japa/snapshot": "^2.0.10",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/lodash": "^4.17.6",
    "@types/node": "^25.3.5",
    "better-sqlite3": "^12.6.2",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.0",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "luxon": "^3.4.4",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "type-fest": "^4.21.0"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "lodash": "^4.17.21"
  },
  "author": {
    "name": "Philippe DESPLATS",
    "email": "hello@dirupt.com"
  },
  "contributors": [
    {
      "name": "Lookin Anton",
      "email": "alf@lookinlab.ru",
      "url": "https://github.com/lookinlab"
    },
    {
      "name": "Dirupt",
      "url": "https://github.com/dirupt-agency"
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/dirupt-agency/adonis-lucid-filter#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dirupt-agency/adonis-lucid-filter.git"
  },
  "bugs": {
    "url": "https://github.com/dirupt-agency/adonis-lucid-filter/issues"
  },
  "keywords": [
    "adonisjs",
    "adonisjs-filter",
    "adonisjs-lucid",
    "adonisjs-lucid-filter",
    "adonis",
    "adonis-lucid",
    "adonis-filter",
    "adonis-lucid-filter",
    "adonisjs-v7"
  ],
  "prettier": "@adonisjs/prettier-config",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**",
      "bin/**"
    ]
  },
  "tsup": {
    "entry": [
      "./index.ts",
      "./src/types/*.ts",
      "./src/bindings/model_query_builder.ts",
      "./commands/make_filter.ts",
      "./providers/lucid_filter_provider.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": false,
    "sourcemap": true,
    "target": "esnext"
  }
}
